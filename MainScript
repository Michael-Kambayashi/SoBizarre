local function getActiveQuestObjective()
    local pGui = player:FindFirstChild("PlayerGui")
    local taskHolder = pGui and pGui:FindFirstChild("menu") and pGui.menu:FindFirstChild("task_holder")
    if not taskHolder then return { type = "NotFound" } end

    local questName = "Unknown Quest"
    for _, v in ipairs(taskHolder:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            local rawTxt = v.ContentText ~= "" and v.ContentText or v.Text
            local txt = rawTxt:gsub("\n", ""):match("^%s*(.-)%s*$")
            if txt and txt ~= "" then
                if questName == "Unknown Quest" and not txt:match("time remain") and not txt:match("%d%d:%d%d") and v.Name ~= "description" and not txt:match("^Defeat") and not txt:match("^Talk") then
                    questName = txt
                end
                local defeatTarget, current, max = txt:match("^Defeat%s+([%w%s]+)%s*[^%d]*(%d+)/(%d+)")
                if defeatTarget then
                    defeatTarget = defeatTarget:match("^%s*(.-)%s*$")
                    if defeatTarget ~= "" then return { type = "Defeat", target = defeatTarget, progress = tonumber(current), max = tonumber(max), questName = questName } end
                end
                local talkTarget = txt:match("^Talk to%s*:?%s*(.*)") or txt:match("^Speak to%s*:?%s*(.*)") or txt:match("^Return to%s*:?%s*(.*)") or txt:match("^Interact with%s*:?%s*(.*)")
                if talkTarget then
                    talkTarget = talkTarget:gsub("[%[%]「」]", ""):gsub("%.%s*$", ""):match("^%s*(.-)%s*$")
                    if talkTarget ~= "" then return { type = "Talk", target = talkTarget, questName = questName } end
                end
            end
        end
    end
    return { type = "NotFound" }
end

local function getQuestTargetMob(mobName)
    local liveFolder = workspace:FindFirstChild("Live")
    if not liveFolder or not mobName or mobName == "" then return nil end
    local searchPrefix = "." .. mobName
    local prefixLen = #searchPrefix
    for _, mob in ipairs(liveFolder:GetChildren()) do
        if string.sub(mob.Name, 1, prefixLen) == searchPrefix then
            local suffix = string.sub(mob.Name, prefixLen + 1)
            if suffix:match("^[%w]*$") then
                local mobHrp = mob:FindFirstChild("HumanoidRootPart")
                local mobHum = mob:FindFirstChild("Humanoid")
                if mobHrp and mobHum and mobHum.Health > 0 then return mob end
            end
        end
    end
    return nil
end

