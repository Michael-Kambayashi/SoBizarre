-- RAID WEBHOOK SCRAPER
-- ==========================================
local function sendRaidWebhook()
    local pGui = player:FindFirstChild("PlayerGui")
    local raidUI = pGui and pGui:FindFirstChild("raidcomplete") and pGui.raidcomplete:FindFirstChild("raid")
    
    if not raidUI then return end

    local rankStr = "Unknown Rank"
    local items = {}

    for _, child in ipairs(raidUI:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") then
            local text = child.Text or ""
            local name = child.Name or ""

            -- Check for Rank
            if string.find(string.upper(text), "RANK") then
                rankStr = text:gsub("\n", "")
            end
            
            -- Check for items (ignoring headers and ranks)
            if name == "misc" and text ~= "Rewards" and text ~= "" and not string.find(string.upper(text), "RANK") then
                local itemName = text:gsub("\n", "")
                
                -- Tally up duplicate items
                if items[itemName] then
                    items[itemName] = items[itemName] + 1
                else
                    items[itemName] = 1
                end
            end
        end
    end

    local rewardsString = ""
    for itemName, count in pairs(items) do
        if count > 1 then
            rewardsString = rewardsString .. "• " .. itemName .. " " .. count .. "x\n"
        else
            rewardsString = rewardsString .. "• " .. itemName .. "\n"
        end
    end

    if rewardsString == "" then rewardsString = "None" end

    local payload = {
        ["username"] = "Bizarre Lineage Logger",
        ["avatar_url"] = "https://tr.rbxcdn.com/38c6edcb50633730ff4cf39ac8859840/150/150/Image/Png",
        ["embeds"] = {{
            ["title"] = "⚔️ Raid Completed!",
            ["description"] = string.format("**%s**\n\n**Rewards:**\n%s", rankStr, rewardsString),
            ["color"] = tonumber("0xFF8C00"), 
            ["footer"] = { ["text"] = "Account: " .. player.Name },
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    }
    
    local req = (syn and syn.request) or (http and http.request) or request or http_request
    if req then
        pcall(function() req({Url = WEBHOOK_URL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)}) end)
    end
end

