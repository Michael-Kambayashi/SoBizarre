local function findTargetNPC(name)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == name and (obj:IsA("Model") or obj:IsA("BasePart")) then return obj end
    end
    if getnilinstances then
        for _, obj in ipairs(getnilinstances()) do
            if obj.Name == name and (obj:IsA("Model") or obj:IsA("BasePart")) then return obj end
        end
    end
    return nil
end

local function aggressiveTeleport(targetCFrame, holdDuration, yOffset)
    yOffset = yOffset or 3 
    targetCFrame = targetCFrame + Vector3.new(0, yOffset, 0)
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    if hrp.Anchored then hrp.Anchored = false end
    local startTime = os.clock()
    while os.clock() - startTime < holdDuration do
        if character and character.Parent then
            character:PivotTo(targetCFrame)
            if hrp then
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end
        end
        task.wait() 
    end
    task.wait(0.2) 
    if not hrp or not hrp.Parent then return false end
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    if distance < 15 then
        hrp.Anchored = true
        task.delay(0.5, function() if hrp then hrp.Anchored = false end end)
        return true
    else
        return false
    end
end

local function getPromptCFrame(prompt)
    if not prompt or not prompt.Parent then return nil end
    local parent = prompt.Parent
    if parent:IsA("Model") then
        local base = parent.PrimaryPart or parent:FindFirstChild("HumanoidRootPart") or parent:FindFirstChildWhichIsA("BasePart")
        return base and base.CFrame or nil
    elseif parent:IsA("BasePart") then
        return parent.CFrame
    end
    return nil
end

local function emergencyUnanchor()
    local c = player.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Anchored then hrp.Anchored = false end
end

