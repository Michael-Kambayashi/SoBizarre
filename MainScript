local lastRollHash = ""

local function getStandJSON()
    local slotData = player:FindFirstChild("PlayerData") and player.PlayerData:FindFirstChild("SlotData")
    local standVal = slotData and slotData:FindFirstChild("Stand")
    if standVal and standVal.Value ~= "" then
        local success, data = pcall(function() return HttpService:JSONDecode(standVal.Value) end)
        if success and type(data) == "table" then return data end
    end
    return nil
end

local function checkRollAndWebhook()
    local data = getStandJSON()
    if not data then return false, "No JSON Data Found", "Unknown" end
    
    local sName = data.Name or "Unknown"
    local sTrait = data.Trait or "None"
    local sSkin = data.Skin or ""
    local hasSkin = sSkin ~= ""
    
    local str = tonumber(data.Strength) or 0
    local spd = tonumber(data.Speed) or 0
    local spec = tonumber(data.Specialty) or 0
    
    local hasAnyMax = (str == 5 or spd == 5 or spec == 5)
    local hasAllMax = (str == 5 and spd == 5 and spec == 5)
    
    local sRarity = STAND_RARITIES[sName] or "Unknown"
    
    local currentHash = sName .. sTrait .. sSkin .. tostring(str) .. tostring(spd) .. tostring(spec)
    if currentHash == lastRollHash then return false, "", sName end
    lastRollHash = currentHash
    
    -- Check Blacklisted Skins
    local isBlacklistedSkin = false
    if hasSkin then
        for _, blacklisted in ipairs(SKIN_BLACKLIST) do
            if sSkin == blacklisted then
                isBlacklistedSkin = true
                break
            end
        end
    end

    -- Filter Matching Logic
    local matchReasons = {}
    if DESIRED_STANDS[sName] then table.insert(matchReasons, "Stand") end
    if DESIRED_RARITIES[sRarity] then table.insert(matchReasons, "Rarity") end
    if DESIRED_TRAITS[sTrait] then table.insert(matchReasons, "Trait (" .. sTrait .. ")") end
    
    -- Modified Logic: Only match "Any Skin" if the skin is NOT in the blacklist
    if DESIRED_EXTRAS["Any Skin"] and hasSkin and not isBlacklistedSkin then table.insert(matchReasons, "Skin") end
    
    if DESIRED_EXTRAS["Any Perfect Stat (5/S)"] and hasAnyMax then table.insert(matchReasons, "Perfect Stat") end
    if DESIRED_EXTRAS["All Perfect Stats (5/S)"] and hasAllMax then table.insert(matchReasons, "All Perfect Stats") end
    
    local isMatch = #matchReasons > 0
    
    -- ONLY send webhook if the roll matched our filters
    if isMatch then
        local reasonStr = table.concat(matchReasons, ", ")
        local embedColor = RARITY_COLORS[sRarity] or RARITY_COLORS["Unknown"]
        local desc = string.format("**Trait:** %s\n**Skin:** %s\n**Strength:** %s\n**Speed:** %s\n**Specialty:** %s\n\n🎯 **Stopped For:** %s",
            sTrait,
            hasSkin and sSkin or "None",
            tostring(str), tostring(spd), tostring(spec),
            reasonStr
        )
        
        local payload = {
            ["username"] = "Bizarre Lineage Logger",
            ["avatar_url"] = "https://tr.rbxcdn.com/38c6edcb50633730ff4cf39ac8859840/150/150/Image/Png",
            ["embeds"] = {{
                ["title"] = "🏹 Rolled: " .. sName .. " | " .. sRarity,
                ["description"] = desc,
                ["color"] = embedColor,
                ["footer"] = { ["text"] = "Account: " .. player.Name },
                ["timestamp"] = DateTime.now():ToIsoDate()
            }}
        }
        
        local req = (syn and syn.request) or (http and http.request) or request or http_request
        if req then
            pcall(function() req({Url = WEBHOOK_URL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)}) end)
        end
        return true, reasonStr, sName
    end
    
    return false, "", sName
end

local function getCurrentConjuration()
    local pGui = player:FindFirstChild("PlayerGui")
    local standInfo = pGui and pGui:FindFirstChild("menu") and pGui.menu:FindFirstChild("Stand Info")
    if standInfo then
        for _, v in ipairs(standInfo:GetDescendants()) do
            if v:IsA("TextLabel") then
                local txt = v.Text:gsub("\n", ""):match("^%s*(.-)%s*$")
                if txt then
                    local match = txt:match("^Stand Conjuration:%s*(%d+)")
                    if match then return tonumber(match) end
                end
            end
        end
    end
    return 0
end

