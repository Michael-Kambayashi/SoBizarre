local function populateDropdown()
    for _, child in ipairs(ddScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local uniqueMobs = {}
    if workspace:FindFirstChild("Live") then
        for _, mob in ipairs(workspace.Live:GetChildren()) do
            if string.find(mob.Name, "Hostage") then continue end
            if string.sub(mob.Name, 1, 1) == "." and mob.Name ~= player.Name then
                local name = mob.Name:sub(2)
                local base = name:match("^(.-)%w%w%w%w%w%w$")
                if not base or base == "" then base = name end
                uniqueMobs[base] = true
            end
        end
    end

    local count = 0
    for mName, _ in pairs(uniqueMobs) do
        local btn = Instance.new("TextButton", ddScroll)
        btn.Size = UDim2.new(1, 0, 0, 25)
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 12
        btn.Text = mName
        btn.ZIndex = 52
        
        btn.MouseButton1Click:Connect(function()
            akTargetMobs[mName] = true
            refreshAkTargetsLabel()
            ddFrame.Visible = false
        end)
        count = count + 1
    end
    ddScroll.CanvasSize = UDim2.new(0, 0, 0, count * 27)
end

