local function getAutoKillTarget()
    local liveFolder = workspace:FindFirstChild("Live")
    if not liveFolder then return nil end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local closestMob = nil
    local closestDist = math.huge

    for _, mob in ipairs(liveFolder:GetChildren()) do
        if string.find(mob.Name, "Hostage") then continue end

        local mobHrp = mob:FindFirstChild("HumanoidRootPart")
        local mobHum = mob:FindFirstChild("Humanoid")
        
        if mobHrp and mobHum and mobHum.Health > 0 then
            if akStopBelow50 and mobHum.Health <= 50 then continue end
            
            if string.sub(mob.Name, 1, 1) == "." and mob.Name ~= player.Name then
                local cleanName = mob.Name:sub(2)
                local isSelected = false
                for sName, _ in pairs(akTargetMobs) do
                    if string.sub(cleanName, 1, #sName) == sName then
                        isSelected = true
                        break
                    end
                end

                local isValidTarget = false
                if akMode == "Include" then isValidTarget = isSelected else isValidTarget = not isSelected end

                if isValidTarget then
                    local dist = (mobHrp.Position - hrp.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closestMob = mob
                    end
                end
            end
        end
    end
    return closestMob
end

local function startAutoKillCycle()
    task.spawn(function()
        while isAutoKilling do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
